{
  "name": "@vouqis/cli",
  "version": "0.4.4",
  "description": "MCP reliability gateway — validates, retries, and audits every AI agent tool call.",
  "type": "module",
  "author": "Vouqis <hello@vouqis.tech>",
  "license": "MIT",
  "homepage": "https://github.com/Sasisundar2211/vouqis",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sasisundar2211/vouqis.git"
  },
  "bin": {
    "vouqis": "bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "oclif": {
    "bin": "vouqis",
    "dirname": "vouqis",
    "commands": {
      "strategy": "pattern",
      "target": "dist/commands"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build && npx oclif manifest",
    "prototype": "npx tsx src/prototype/tui.ts"
  },
  "dependencies": {
    "@oclif/core": "^4",
    "chalk": "^5",
    "posthog-node": "^5.36.4",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25",
    "esbuild": "^0.28.1",
    "tsup": "^8",
    "typescript": "^6",
    "vitest": "^4"
  },
  "engines": {
    "node": ">=20"
  }
}
