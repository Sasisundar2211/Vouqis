{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vouqis.tech/schemas/report.v1.json",
  "title": "Vouqis Audit Report",
  "description": "Machine-readable output of a vouqis audit run",
  "type": "object",
  "required": ["$schema","version","timestamp","serverUrl","trustScore","results","remediation"],
  "properties": {
    "$schema": {"type":"string"},
    "version": {"type":"string"},
    "timestamp": {"type":"string","format":"date-time"},
    "serverUrl": {"type":"string","format":"uri"},
    "trustScore": {
      "type":"object",
      "required":["score","passRate","p50LatencyMs","errorsByFailureMode","totalPrompts","passedPrompts"],
      "properties": {
        "score":{"type":"integer","minimum":0,"maximum":100},
        "passRate":{"type":"number","minimum":0,"maximum":1},
        "p50LatencyMs":{"type":"integer"},
        "errorsByFailureMode":{"type":"object","additionalProperties":{"type":"integer"}},
        "totalPrompts":{"type":"integer"},
        "passedPrompts":{"type":"integer"}
      }
    },
    "results": {
      "type":"array",
      "items":{
        "type":"object",
        "required":["promptId","failureMode","passed","durationMs"],
        "properties":{
          "promptId":{"type":"string"},
          "failureMode":{"type":"string"},
          "passed":{"type":"boolean"},
          "durationMs":{"type":"integer"},
          "errorText":{"type":"string"},
          "toolCalled":{"type":"string"}
        }
      }
    },
    "remediation": {
      "type":"array",
      "items":{
        "type":"object",
        "required":["probe","category","issue","fix","severity","docsUrl"],
        "properties":{
          "probe":{"type":"string"},
          "category":{"type":"string"},
          "issue":{"type":"string"},
          "fix":{"type":"string"},
          "severity":{"type":"string","enum":["critical","high","medium"]},
          "docsUrl":{"type":"string","format":"uri"}
        }
      }
    }
  }
}
